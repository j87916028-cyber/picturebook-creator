# ── 必填 ──────────────────────────────────────────────────────
# MiniMax AI（劇本生成主力 LLM）— https://www.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# ── 選填（功能增強）─────────────────────────────────────────
# Groq（劇本 fallback LLM + Whisper 語音辨識 + Orpheus TTS fallback）
GROQ_API_KEY=your_groq_api_key_here

# 科大訊飛 TTS（免費額度，中文品質最佳）— https://www.xfyun.cn/
# 建立應用後在「語音合成」服務頁面取得以下三個值
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# HuggingFace Inference API（FLUX.1-schnell 圖片生成）
# 免費 token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Pollinations.ai（圖片生成 fallback）— https://auth.pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# ── 基礎設施 ──────────────────────────────────────────────
# PostgreSQL 連線（Docker 環境下使用 docker-compose.yml 中的預設值）
DATABASE_URL=postgresql://app:secret@postgres:5432/picturebook

# CORS 允許來源（逗號分隔，預設 localhost:5173,localhost:3000）
# 生產環境請改為實際域名，例如 https://picturebook.example.com
CORS_ORIGINS=
