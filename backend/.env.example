MINIMAX_API_KEY=your_minimax_api_key_here
# 科大訊飛 TTS（免費額度，中文品質最佳）— https://www.xfyun.cn/
# 建立應用後在「語音合成」服務頁面取得以下三個值
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
GROQ_API_KEY=your_groq_api_key_here
# GEMINI_API_KEY: needs billing enabled at https://aistudio.google.com for image generation
GEMINI_API_KEY=your_gemini_api_key_here
# HUGGINGFACE_API_KEY: free tier at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# POLLINATIONS_API_KEY: free tier at https://auth.pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_api_key_here
DATABASE_URL=postgresql://app:secret@postgres:5432/picturebook
